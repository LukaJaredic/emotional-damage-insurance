{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": [
      "vitest/globals",
      "@testing-library/jest-dom",
      "vite/client",
      "node"
    ],
    "jsx": "react-jsx"
  },
  "include": [
    "src/**/*.d.ts",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/testing/**/*.ts",
    "src/testing/**/*.tsx"
  ]
}
